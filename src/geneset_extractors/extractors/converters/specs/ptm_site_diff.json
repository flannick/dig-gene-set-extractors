{
  "name": "ptm_site_diff",
  "description": "Site-level PTM differential table converted to signed gene programs and GMT gene sets",
  "inputs": [
    {
      "name": "ptm_tsv",
      "type": "tsv",
      "description": "Site-level PTM differential table",
      "required": true
    }
  ],
  "parameters": [
    {"name": "signature_name", "type": "string", "default": null, "help": "Optional signature label for metadata/GMT naming; default uses ptm_tsv stem"},
    {"name": "dataset_label", "type": "string", "default": null, "help": "Optional dataset label for run summaries; default uses input filename"},
    {"name": "ptm_type", "type": "string", "default": "phospho", "enum": ["phospho", "acetyl", "ub", "generic"], "help": "PTM class used for canonical site keys and bundle defaults"},
    {"name": "site_id_column", "type": "string", "default": null, "help": "Optional stable site identifier column override"},
    {"name": "site_group_column", "type": "string", "default": null, "help": "Optional site-group identifier column override"},
    {"name": "gene_id_column", "type": "string", "default": null, "help": "Optional gene_id column override"},
    {"name": "gene_symbol_column", "type": "string", "default": null, "help": "Optional gene_symbol column override"},
    {"name": "protein_accession_column", "type": "string", "default": null, "help": "Optional protein accession column override"},
    {"name": "residue_column", "type": "string", "default": null, "help": "Optional residue column override"},
    {"name": "position_column", "type": "string", "default": null, "help": "Optional residue position column override"},
    {"name": "score_column", "type": "string", "default": null, "help": "Custom score column when score_mode=custom_column"},
    {"name": "stat_column", "type": "string", "default": null, "help": "Site statistic column for score_mode=stat"},
    {"name": "logfc_column", "type": "string", "default": null, "help": "Site log fold-change column"},
    {"name": "padj_column", "type": "string", "default": null, "help": "Adjusted p-value column"},
    {"name": "pvalue_column", "type": "string", "default": null, "help": "P-value fallback column"},
    {"name": "localization_prob_column", "type": "string", "default": null, "help": "Localization confidence column"},
    {"name": "peptide_count_column", "type": "string", "default": null, "help": "Peptide/evidence count column"},
    {"name": "protein_logfc_column", "type": "string", "default": null, "help": "Matched total-protein logFC column"},
    {"name": "protein_stat_column", "type": "string", "default": null, "help": "Matched total-protein statistic column"},
    {"name": "score_mode", "type": "string", "default": "auto", "enum": ["auto", "stat", "logfc_times_neglog10p", "custom_column"], "help": "Base site score definition"},
    {"name": "score_transform", "type": "string", "default": "signed", "enum": ["signed", "abs", "positive", "negative"], "help": "Signed or nonnegative row-score transform"},
    {"name": "protein_adjustment", "type": "string", "default": "subtract", "enum": ["none", "subtract", "residual"], "help": "Adjust site scores by matched total-protein change"},
    {"name": "protein_adjustment_lambda", "type": "number", "default": 1.0, "help": "Coefficient for protein_adjustment=subtract"},
    {"name": "confidence_weight_mode", "type": "string", "default": "combined", "enum": ["none", "pvalue", "localization", "combined"], "help": "Confidence weighting strategy"},
    {"name": "min_localization_prob", "type": "number", "default": 0.75, "help": "Minimum localization probability contributing positive weight"},
    {"name": "site_dup_policy", "type": "string", "default": "highest_confidence", "enum": ["highest_confidence", "max_abs", "mean", "sum"], "help": "Duplicate-row collapse policy per canonical site"},
    {"name": "gene_aggregation", "type": "string", "default": "signed_topk_mean", "enum": ["signed_topk_mean", "max_abs", "sum", "mean"], "help": "Site-to-gene aggregation method"},
    {"name": "gene_topk_sites", "type": "integer", "default": 3, "help": "K for gene_aggregation=signed_topk_mean"},
    {"name": "ambiguous_gene_policy", "type": "string", "default": "drop", "enum": ["drop", "split_equal", "first"], "help": "How ambiguous multi-gene rows are handled"},
    {"name": "neglog10p_cap", "type": "number", "default": 50.0, "help": "Cap for -log10(p) in logfc_times_neglog10p mode"},
    {"name": "neglog10p_eps", "type": "number", "default": 1e-300, "help": "Numerical floor for p-values"},
    {"name": "resources_manifest", "type": "string", "default": null, "help": "Optional resources manifest path"},
    {"name": "resources_dir", "type": "string", "default": null, "help": "Optional resources directory containing PTM bundle files"},
    {"name": "resource_policy", "type": "string", "default": "skip", "enum": ["skip", "fail"], "help": "Behavior when requested PTM resources are missing"},
    {"name": "use_reference_bundle", "type": "boolean", "default": true, "help": "Attempt to use alias and ubiquity priors when available"},
    {"name": "site_alias_resource_id", "type": "string", "default": null, "help": "Optional resource id for canonical site alias table"},
    {"name": "site_ubiquity_resource_id", "type": "string", "default": null, "help": "Optional resource id for site ubiquity prior"},
    {"name": "select", "type": "string", "default": "top_k", "enum": ["none", "top_k", "quantile", "threshold"], "help": "Gene selection method using abs(score)"},
    {"name": "top_k", "type": "integer", "default": 200, "help": "K for select=top_k"},
    {"name": "quantile", "type": "number", "default": 0.01, "help": "Fraction for select=quantile"},
    {"name": "min_score", "type": "number", "default": 0.0, "help": "Minimum abs(score) for select=threshold"},
    {"name": "normalize", "type": "string", "default": "within_set_l1", "enum": ["none", "l1", "within_set_l1"], "help": "Weight normalization on selected genes"},
    {"name": "emit_full", "type": "boolean", "default": true, "help": "Write geneset.full.tsv"},
    {"name": "emit_gmt", "type": "boolean", "default": true, "help": "Write genesets.gmt"},
    {"name": "gmt_format", "type": "string", "default": "dig2col", "enum": ["dig2col", "classic"], "help": "GMT serialization format"},
    {"name": "gmt_prefer_symbol", "type": "boolean", "default": true, "help": "Prefer gene_symbol tokens in GMT"},
    {"name": "gmt_require_symbol", "type": "boolean", "default": true, "help": "Drop rows without usable symbol tokens for GMT"},
    {"name": "gmt_biotype_allowlist", "type": "string", "default": "protein_coding", "help": "Comma-separated allowed biotypes for GMT"},
    {"name": "gmt_split_signed", "type": "boolean", "default": true, "help": "Emit __pos and __neg GMT families from signed scores"},
    {"name": "gmt_topk_list", "type": "string", "default": "200", "help": "Comma-separated top-K GMT plans"},
    {"name": "gmt_mass_list", "type": "string", "default": "", "help": "Comma-separated mass GMT plans"},
    {"name": "gmt_min_genes", "type": "integer", "default": 100, "help": "Minimum genes per GMT set"},
    {"name": "gmt_max_genes", "type": "integer", "default": 500, "help": "Maximum genes per GMT set"},
    {"name": "emit_small_gene_sets", "type": "boolean", "default": false, "help": "Emit sets below gmt_min_genes with warning"}
  ],
  "outputs": [
    {"name": "geneset.tsv", "description": "Selected PTM-derived gene program with signed score and nonnegative weight"},
    {"name": "geneset.meta.json", "description": "Run metadata and provenance"},
    {"name": "geneset.full.tsv", "description": "Full ranked PTM-derived gene score table (optional)"},
    {"name": "genesets.gmt", "description": "Directional GMT gene sets (optional)"},
    {"name": "run_summary.json", "description": "Machine-readable PTM run summary"},
    {"name": "run_summary.txt", "description": "Human-readable PTM run summary"}
  ]
}
