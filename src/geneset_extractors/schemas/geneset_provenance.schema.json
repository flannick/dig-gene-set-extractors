{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "geneset.provenance.schema.json",
  "title": "Single Gene Set Replayable Provenance",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "replay",
    "linked_data",
    "c2m2"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "record_type": {
      "const": "single_geneset"
    },
    "replay": {
      "type": "object",
      "required": [
        "geneset",
        "software",
        "inputs",
        "steps",
        "target_output"
      ]
    },
    "linked_data": {
      "type": "object",
      "required": [
        "@context",
        "@graph"
      ],
      "properties": {
        "@graph": {
          "type": "array"
        }
      }
    },
    "c2m2": {
      "type": "object",
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array"
        },
        "edges": {
          "type": "array"
        }
      }
    }
  }
}
