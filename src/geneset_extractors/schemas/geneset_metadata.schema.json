{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "standard_name",
    "standard_version",
    "file_type",
    "schema_version",
    "created_at",
    "geneset_id",
    "gene_set",
    "converter",
    "input",
    "gene_annotation",
    "weights",
    "summary",
    "output",
    "provenance"
  ],
  "properties": {
    "standard_name": {"const": "dig.geneset"},
    "standard_version": {"type": "string"},
    "file_type": {"const": "metadata"},
    "schema_version": {"type": "string"},
    "created_at": {"type": "string"},
    "geneset_id": {"type": "string"},
    "gene_set": {
      "type": "object",
      "required": ["id", "name", "assay", "data_type", "organism", "genome_build", "n_genes", "primary_artifact"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "assay": {"type": "string"},
        "data_type": {"type": "string"},
        "organism": {"type": "string"},
        "genome_build": {"type": "string"},
        "n_genes": {"type": "integer"},
        "primary_artifact": {
          "type": "object",
          "required": ["path", "role"],
          "properties": {
            "path": {"type": "string"},
            "role": {"type": "string"}
          }
        }
      }
    },
    "converter": {
      "type": "object",
      "required": ["name", "version", "parameters", "code", "execution"],
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"},
        "parameters": {"type": "object"},
        "code": {"type": "object"},
        "execution": {"type": "object"}
      }
    },
    "input": {
      "type": "object",
      "required": ["data_type", "assay", "organism", "genome_build", "files"],
      "properties": {
        "data_type": {"type": "string"},
        "assay": {"type": "string"},
        "organism": {"type": "string"},
        "genome_build": {"type": "string", "minLength": 1},
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "role", "sha256"],
            "properties": {
              "path": {"type": "string"},
              "local_path": {"type": "string"},
              "role": {"type": "string"},
              "sha256": {"type": "string"},
              "size_bytes": {"type": "integer"},
              "canonical_uri": {"type": ["string", "null"]},
              "download_url": {"type": ["string", "null"]},
              "landing_page_url": {"type": ["string", "null"]},
              "persistent_id": {"type": ["string", "null"]},
              "provider": {"type": ["string", "null"]},
              "version": {"type": ["string", "null"]},
              "license": {"type": ["string", "null"]},
              "access_level": {"type": ["string", "null"]},
              "extensions": {"type": "object"}
            }
          }
        }
      }
    },
    "gene_annotation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["mode", "gtf_path", "source", "gene_id_field"],
          "properties": {
            "mode": {"const": "gtf"},
            "gtf_path": {"type": "string", "minLength": 1},
            "source": {"type": "string"},
            "gene_id_field": {"type": "string"}
          }
        },
        {
          "type": "object",
          "required": ["mode", "source", "gene_id_field"],
          "properties": {
            "mode": {"const": "none"},
            "source": {"type": "string"},
            "gene_id_field": {"type": "string"}
          }
        }
      ]
    },
    "weights": {
      "type": "object",
      "required": ["weight_type", "normalization", "aggregation"],
      "properties": {
        "weight_type": {"type": "string"},
        "normalization": {"type": "object"},
        "aggregation": {"type": "string"}
      }
    },
    "program_extraction": {
      "type": "object",
      "required": ["selection_method", "selection_params", "normalize", "n_selected_genes", "score_definition"],
      "properties": {
        "selection_method": {"type": "string"},
        "selection_params": {"type": "object"},
        "normalize": {"type": "string"},
        "n_selected_genes": {"type": "integer"},
        "score_definition": {"type": "string"},
        "study_contrast": {"type": "object"},
        "contrast": {"type": "object"}
      }
    },
    "output": {
      "type": "object",
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "role"],
            "properties": {
              "path": {"type": "string"},
              "role": {"type": "string"}
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["path", "focus_node_id"],
      "properties": {
        "path": {"type": "string"},
        "focus_node_id": {"type": "string"}
      }
    },
    "gmt": {
      "type": "object",
      "required": ["written", "path", "prefer_symbol", "min_genes", "max_genes", "plans"],
      "properties": {
        "written": {"type": "boolean"},
        "path": {"type": ["string", "null"]},
        "prefer_symbol": {"type": "boolean"},
        "min_genes": {"type": "integer"},
        "max_genes": {"type": "integer"},
        "plans": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "method", "parameters", "n_genes_emitted", "token_type", "n_duplicates_dropped"],
            "properties": {
              "name": {"type": "string"},
              "method": {"type": "string"},
              "parameters": {"type": "object"},
              "n_genes_emitted": {"type": "integer"},
              "token_type": {"type": "string"},
              "n_duplicates_dropped": {"type": "integer"}
            }
          }
        }
      }
    },
    "lineage": {
      "type": "object",
      "required": ["graph_version", "nodes", "edges", "processes"],
      "properties": {
        "graph_version": {"type": "string"},
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "node_type", "direction", "role", "path"],
            "properties": {
              "id": {"type": "string"},
              "node_type": {"const": "file"},
              "direction": {"type": "string"},
              "role": {"type": "string"},
              "path": {"type": "string"},
              "sha256": {"type": "string"},
              "media_type": {"type": "string"}
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "source", "target", "process_id", "edge_type"],
            "properties": {
              "id": {"type": "string"},
              "source": {"type": "string"},
              "target": {"type": "string"},
              "process_id": {"type": "string"},
              "edge_type": {"type": "string"}
            }
          }
        },
        "processes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "process_type",
              "command_kind",
              "command_argv",
              "command",
              "working_directory",
              "entrypoint",
              "parameters",
              "code"
            ],
            "properties": {
              "id": {"type": "string"},
              "name": {"type": "string"},
              "process_type": {"type": "string"},
              "command_kind": {"type": "string"},
              "command_argv": {
                "type": "array",
                "items": {"type": "string"}
              },
              "command": {"type": "string"},
              "working_directory": {"type": "string"},
              "entrypoint": {"type": "object"},
              "parameters": {"type": "object"},
              "code": {"type": "object"}
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["n_input_features", "n_genes", "n_features_assigned", "fraction_features_assigned"],
      "properties": {
        "n_input_features": {"type": "integer"},
        "n_genes": {"type": "integer"},
        "n_features_assigned": {"type": "integer"},
        "fraction_features_assigned": {"type": "number"}
      }
    }
  }
}
